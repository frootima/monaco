# The defaults below intentionally create the requested local POC login.
# Change the password before exposing Jenkins outside localhost.
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin
JENKINS_URL=http://localhost:8081/
JENKINS_HTTP_PORT=8081
JENKINS_AGENT_PORT=50001

# Create an API token in Dynatrace with DataExport, ReadConfig, WriteConfig,
# settings.read, and settings.write scopes. Never commit the real value.
DYNATRACE_API_TOKEN=REPLACE_WITH_DYNATRACE_API_TOKEN

# Platform dashboard documents require a separate Platform token.
# Required scopes are documented in README.md.
DYNATRACE_PLATFORM_TOKEN=REPLACE_WITH_DYNATRACE_PLATFORM_TOKEN

# Docker Desktop exposes this socket as group 1002 in containers on this host.
# For another host, run the discovery command documented in README.md.
DOCKER_GID=1002
